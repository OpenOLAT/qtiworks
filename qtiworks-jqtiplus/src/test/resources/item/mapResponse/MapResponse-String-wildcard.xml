<assessmentItem xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqti_v2p1 http://www.imsglobal.org/xsd/imsqti_v2p1.xsd"
 xmlns="http://www.imsglobal.org/xsd/imsqti_v2p1"
 adaptive="false"
 identifier="MapResponse-Single"
 timeDependent="false"
 title="MapResponse (chemical with wildcard)">
    <responseDeclaration identifier="RESPONSE" cardinality="single" baseType="string">
        <mapping defaultValue="-1">
            <mapEntry mapKey="[CH2]([NH2])[C]([OH])=[O]" mappedValue="8.0" caseSensitive="true"/>
            <mapEntry mapKey="*[CH2]*[C]([OH])=[O]*" mappedValue="6.0" caseSensitive="true"/>
            <mapEntry mapKey="[CH2]*[C]*([OH])=[O]" mappedValue="5.0" caseSensitive="true"/>
            <mapEntry mapKey="*[CH2]([NH2])[C]*" mappedValue="2.0" caseSensitive="true"/>
            <mapEntry mapKey="*([OH])=[O]*" mappedValue="1.0" caseSensitive="true"/>
        </mapping>
    </responseDeclaration>
    <outcomeDeclaration identifier="OUTCOME" cardinality="single" baseType="float"/>
    <itemBody>
    	<p><textEntryInteraction class="oo-wildcard-oo" responseIdentifier="RESPONSE" ></textEntryInteraction></p>
    </itemBody>
    <responseProcessing>
        <setOutcomeValue identifier="OUTCOME">
            <mapResponse identifier="RESPONSE"/>
        </setOutcomeValue>
    </responseProcessing>
</assessmentItem>
